{
  "name": "fdn-formkit-theme",
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/formkit/theme-starter.git"
  },
  "author": "",
  "license": "MIT",
  "main": "dist/theme.cjs",
  "module": "dist/theme.js",
  "types": "dist/theme.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/theme.d.ts",
        "default": "./dist/theme.js"
      },
      "require": {
        "types": "./dist/theme.d.cts",
        "default": "./dist/theme.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsup",
    "build-web": "vite build",
    "preview": "vite preview",
    "release": "pnpm build && npx publint && npx bumpp --push",
    "test": "vitest",
    "lint": "eslint",
    "generate": "pnpm build && npx formkit@latest theme --theme=dist/theme.js && mv formkit.theme.ts ../"

  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@formkit/theme-creator": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@formkit/addons": "latest",
    "@formkit/barcode": "latest",
    "@formkit/icons": "latest",
    "@formkit/pro": "next",
    "@formkit/theme-editor": "^0.6.2",
    "@formkit/vue": "latest",
    "@vitejs/plugin-vue": "^4.6.2",
    "bumpp": "^9.3.0",
    "eslint": "^9.39.1",
    "formkit": "^1.7.2",
    "prettier": "^3.2.5",
    "publint": "^0.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.32.1",
    "vite": "^4.5.2",
    "vitest": "^0.34.6",
    "vue": "^3.4.15",
    "vue-tsc": "^1.8.27"
  },
  "description": "A FormKit theme.",
  "contributors": [
    "Alcides"
  ]
}
